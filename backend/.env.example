# ═══════════════════════════════════════════════
# ITZ Cases — Variáveis de Ambiente (Vercel + Neon)
# ═══════════════════════════════════════════════
# Local:    copie este arquivo para .env e preencha os valores.
# Vercel:   a integração Neon injeta automaticamente DATABASE_URL.
#           As outras vars você configura em Settings → Environment Variables.
# NUNCA commite o .env no git.

# ─── Banco (Neon / Postgres) ────────────────────
# Quando você conecta Neon via Vercel Marketplace, essa var é injetada
# automaticamente. Para dev local, copie do dashboard Neon → Connect → Pooled.
DATABASE_URL=postgresql://user:pass@xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Ambiente ───────────────────────────────────
NODE_ENV=production

# ─── Autenticação ───────────────────────────────
# Gere com:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-essa-chave-por-uma-aleatoria-de-64-bytes

# Gere o hash com:  node -e "console.log(require('bcryptjs').hashSync('SuaSenha',12))"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$12$exemplo.troque.isso.gerando.com.o.comando.acima

JWT_EXPIRY=24h

# ─── CORS ───────────────────────────────────────
# Em produção coloque o domínio exato da Vercel (ex: https://cases-mocha.vercel.app)
# Em dev pode usar *
CORS_ORIGIN=*

# ─── Dev local (opcional) ───────────────────────
PORT=3001
