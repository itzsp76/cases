# ═══════════════════════════════════════════════
# ITZ Cases — Variáveis de Ambiente (Vercel + Supabase)
# ═══════════════════════════════════════════════
# Local:    copie este arquivo para .env e preencha os valores.
# Vercel:   a integração Supabase injeta automaticamente as vars POSTGRES_*.
#           As outras vars você configura em Settings → Environment Variables.
# NUNCA commite o .env no git.

# ─── Banco (Supabase / Postgres) ────────────────
# Local: Supabase → Project Settings → Database → Connection string → URI
#        USE A "Transaction pooler" (porta 6543) — apropriada para serverless.
#        Troque [YOUR-PASSWORD] pela senha real do banco.
# Vercel: ao conectar via Marketplace, POSTGRES_URL é injetado automaticamente.
#        O código lê DATABASE_URL || POSTGRES_URL.
DATABASE_URL=postgresql://postgres.xxxxx:SENHA@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Ambiente ───────────────────────────────────
NODE_ENV=production

# ─── Autenticação ───────────────────────────────
# Gere com:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-essa-chave-por-uma-aleatoria-de-64-bytes

# Gere o hash com:  node -e "console.log(require('bcryptjs').hashSync('SuaSenha',12))"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$12$exemplo.troque.isso.gerando.com.o.comando.acima

JWT_EXPIRY=24h

# ─── CORS ───────────────────────────────────────
# Em produção coloque o domínio exato da Vercel (ex: https://cases-mocha.vercel.app)
# Em dev pode usar *
CORS_ORIGIN=*

# ─── Dev local (opcional) ───────────────────────
PORT=3001
