# ═══════════════════════════════════════════════
# ITZ Cases — Configuração do Backend
# ═══════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no git.

# Porta do servidor (padrão 3001)
PORT=3001

# Ambiente (development | production)
NODE_ENV=production

# Secret para assinar JWTs. Gere uma chave forte:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-essa-chave-por-uma-aleatoria-de-64-bytes

# Credenciais do admin
# A senha fica armazenada como HASH (bcrypt). Para gerar o hash:
#   node -e "console.log(require('bcryptjs').hashSync('SuaSenhaAqui', 12))"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$12$exemplo.troque.isso.gerando.com.o.comando.acima

# Origem permitida (CORS). Em produção, coloque o domínio exato.
# Em dev, pode usar * para facilitar testes.
CORS_ORIGIN=https://cases.itzinteligencia.com.br

# Caminho do banco SQLite (relativo à raiz do backend)
DB_PATH=./data/itz-cases.db

# Duração do token JWT (formato: 1h, 24h, 7d)
JWT_EXPIRY=24h
