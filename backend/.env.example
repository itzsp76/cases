# ═══════════════════════════════════════════════
# ITZ Cases — Variáveis de Ambiente
# ═══════════════════════════════════════════════
# Local:    copie este arquivo para .env e preencha os valores.
# Vercel:   configure as mesmas vars em Project → Settings → Environment Variables.
# NUNCA commite o .env no git.

# ─── Banco (Turso) ──────────────────────────────
# Crie em https://turso.tech → Database → Show URL / Create Token
TURSO_DATABASE_URL=libsql://seu-db-xxx.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...seu-token-jwt

# ─── Ambiente ───────────────────────────────────
NODE_ENV=production

# ─── Autenticação ───────────────────────────────
# Gere com:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-essa-chave-por-uma-aleatoria-de-64-bytes

# Gere o hash com:  node -e "console.log(require('bcryptjs').hashSync('SuaSenha',12))"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$12$exemplo.troque.isso.gerando.com.o.comando.acima

JWT_EXPIRY=24h

# ─── CORS ───────────────────────────────────────
# Em produção coloque o domínio exato da Vercel (ex: https://cases.vercel.app)
# Em dev pode usar *
CORS_ORIGIN=*

# ─── Dev local (opcional) ───────────────────────
PORT=3001
